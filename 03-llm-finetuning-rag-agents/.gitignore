__pycache__/
*.pyc
.ipynb_checkpoints/
.env
.venv/
venv/

# data + model artifacts (large / reproducible)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
outputs/checkpoints/*
